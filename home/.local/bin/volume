#!/bin/bash

# Volume control with dunst OSD notification
# Usage: volume up | down | mute

STEP=5
MAX_VOL=100
NOTIFY_ID=2593 # fixed ID so notifications replace each other

get_volume() {
    wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf "%.0f", $2 * 100}'
}

is_muted() {
    wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED
}

send_notification() {
    local vol="$1"
    local icon

    if is_muted || [ "$vol" -eq 0 ]; then
        icon="audio-volume-muted-symbolic"
        dunstify -a "volume" -u low -r "$NOTIFY_ID" -i "$icon" -h string:x-dunst-stack-tag:volume -h int:value:0 "Muted"
    elif [ "$vol" -le 30 ]; then
        icon="audio-volume-low-symbolic"
        dunstify -a "volume" -u low -r "$NOTIFY_ID" -i "$icon" -h string:x-dunst-stack-tag:volume -h int:value:"$vol" "Volume: ${vol}%"
    elif [ "$vol" -le 70 ]; then
        icon="audio-volume-medium-symbolic"
        dunstify -a "volume" -u low -r "$NOTIFY_ID" -i "$icon" -h string:x-dunst-stack-tag:volume -h int:value:"$vol" "Volume: ${vol}%"
    else
        icon="audio-volume-high-symbolic"
        dunstify -a "volume" -u low -r "$NOTIFY_ID" -i "$icon" -h string:x-dunst-stack-tag:volume -h int:value:"$vol" "Volume: ${vol}%"
    fi
}

case "$1" in
    up)
        wpctl set-mute @DEFAULT_AUDIO_SINK@ 0
        wpctl set-volume -l "$(awk "BEGIN{printf \"%.2f\", $MAX_VOL/100}")" @DEFAULT_AUDIO_SINK@ "${STEP}%+"
        send_notification "$(get_volume)"
        ;;
    down)
        wpctl set-mute @DEFAULT_AUDIO_SINK@ 0
        wpctl set-volume @DEFAULT_AUDIO_SINK@ "${STEP}%-"
        send_notification "$(get_volume)"
        ;;
    mute)
        wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
        send_notification "$(get_volume)"
        ;;
    *)
        echo "Usage: volume up|down|mute"
        exit 1
        ;;
esac
