#!/usr/bin/env bash
# theme-apply — apply a theme across all visual elements
# Usage: theme-apply <theme-slug>
# Available: catppuccin-mocha, gruvbox-dark, nord, tokyo-night, dracula, rose-pine

set -euo pipefail

THEMES_DIR="$HOME/.config/themes/colors"
CURRENT_FILE="$HOME/.config/themes/current"

theme="${1:-}"

if [[ -z "$theme" ]]; then
    echo "Usage: theme-apply <theme-slug>"
    echo "Available themes:"
    for f in "$THEMES_DIR"/*.sh; do
        basename "$f" .sh
    done
    exit 1
fi

theme_file="$THEMES_DIR/${theme}.sh"
if [[ ! -f "$theme_file" ]]; then
    echo "Theme '$theme' not found in $THEMES_DIR"
    exit 1
fi

# shellcheck source=/dev/null
source "$theme_file"

# Helper: convert #rrggbb to rgba(r,g,b,alpha) for CSS
hex_to_rgba() {
    local hex="${1#\#}"
    local alpha="${2:-1}"
    printf "rgba(%d, %d, %d, %s)" "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}" "$alpha"
}

# Helper: strip # for hyprland rgba format
hex_to_hypr() {
    local hex="${1#\#}"
    local alpha="${2:-ee}"
    echo "rgba(${hex}${alpha})"
}

notify() {
    notify-send -t 3000 -i preferences-desktop-theme "Theme Switcher" "$1" 2>/dev/null || true
}

echo "Applying theme: $THEME_NAME"

# ─── 1. Hyprland look-and-feel.conf ──────────────────────────────
cat > "$HOME/.config/hypr/look-and-feel.conf" << EOF
# Refer to https://wiki.hypr.land/Configuring/Variables/
# Theme: $THEME_NAME (auto-generated by theme-apply)

# https://wiki.hypr.land/Configuring/Variables/#general
general {
    gaps_in = 5
    gaps_out = 10
    border_size = 2
    col.active_border = $(hex_to_hypr "$ACCENT" "ee") $(hex_to_hypr "$ACCENT2" "ee") 45deg
    col.inactive_border = $(hex_to_hypr "$SURFACE1" "aa")
    resize_on_border = false
    allow_tearing = true  # for gaming (immediate windowrule)
    layout = dwindle
}

# https://wiki.hypr.land/Configuring/Variables/#decoration
decoration {
    rounding = 10

    active_opacity = 1.0
    inactive_opacity = 1.0

    blur {
        enabled = false
        size = 6
        passes = 3
        new_optimizations = true
        xray = false
    }

    shadow {
        enabled = true
        range = 15
        render_power = 3
        color = $(hex_to_hypr "$BG_DARK" "ee")
    }
}

# https://wiki.hypr.land/Configuring/Variables/#animations
animations {
    enabled = true

    bezier = smoothOut, 0.36, 0, 0.66, -0.56
    bezier = smoothIn, 0.25, 1, 0.5, 1
    bezier = overshot, 0.05, 0.9, 0.1, 1.1

    animation = windows, 1, 4, overshot, slide
    animation = windowsOut, 1, 4, smoothOut, slide
    animation = border, 1, 10, default
    animation = borderangle, 1, 40, default, loop
    animation = fade, 1, 4, smoothIn
    animation = workspaces, 1, 5, overshot, slidevert
}

# See https://wiki.hypr.land/Configuring/Dwindle-Layout/ for more
dwindle {
    pseudotile = true
    preserve_split = true
    force_split = 2
}

# https://wiki.hypr.land/Configuring/Variables/#misc
misc {
    force_default_wallpaper = 0
    disable_hyprland_logo = true
}
EOF

# ─── 2. Kitty terminal theme ─────────────────────────────────────
cat > "$HOME/.config/kitty/current-theme.conf" << EOF
# vim:ft=kitty
## name:     $THEME_NAME
## auto-generated by theme-apply

# The basic colors
foreground              $FG
background              $BG
selection_foreground    $BG
selection_background    $ROSEWATER

# Cursor colors
cursor                  $ROSEWATER
cursor_text_color       $BG

# URL underline color when hovering with mouse
url_color               $ROSEWATER

# Kitty window border colors
active_border_color     $LAVENDER
inactive_border_color   $OVERLAY0
bell_border_color       $YELLOW

# OS Window titlebar colors
wayland_titlebar_color system
macos_titlebar_color system

# Tab bar colors
active_tab_foreground   $BG_DARK
active_tab_background   $ACCENT2
inactive_tab_foreground $FG
inactive_tab_background $BG_DIM
tab_bar_background      $BG_DARK

# Colors for marks (marked text in the terminal)
mark1_foreground $BG
mark1_background $LAVENDER
mark2_foreground $BG
mark2_background $ACCENT2
mark3_foreground $BG
mark3_background $SAPPHIRE

# The 16 terminal colors

# black
color0 $COLOR0
color8 $COLOR8

# red
color1 $COLOR1
color9 $COLOR9

# green
color2  $COLOR2
color10 $COLOR10

# yellow
color3  $COLOR3
color11 $COLOR11

# blue
color4  $COLOR4
color12 $COLOR12

# magenta
color5  $COLOR5
color13 $COLOR13

# cyan
color6  $COLOR6
color14 $COLOR14

# white
color7  $COLOR7
color15 $COLOR15
EOF

# ─── 3. Waybar style.css ─────────────────────────────────────────
cat > "$HOME/.config/waybar/style.css" << EOF
/* Theme: $THEME_NAME (auto-generated by theme-apply) */
* {
    font-family: "JetBrainsMono Nerd Font", "Font Awesome 6 Free";
    font-size: 13px;
    min-height: 0;
}

window#waybar {
    background: transparent;
    color: $FG;
}

/* ── Split bar: 3 independent sections ── */
.modules-left,
.modules-center,
.modules-right {
    background: $(hex_to_rgba "$BG_DARK" "0.85");
    border-radius: 12px;
    border: 2px solid $(hex_to_rgba "$ACCENT" "0.4");
    padding: 0 4px;
    margin: 0 0;
}

/* Modules */
#workspaces button {
    padding: 0 8px;
    color: $OVERLAY0;
    border-radius: 8px;
    margin: 4px 2px;
    transition: all 0.2s ease;
}

#workspaces button.active {
    color: $ACCENT;
    background: $(hex_to_rgba "$ACCENT" "0.15");
}

#workspaces button:hover {
    color: $LAVENDER;
    background: $(hex_to_rgba "$LAVENDER" "0.1");
}

#clock, #cpu, #memory, #temperature, #pulseaudio, #network, #tray, #custom-brightness {
    padding: 0 12px;
    margin: 4px 2px;
    border-radius: 8px;
}

#clock {
    color: $ACCENT;
    font-weight: bold;
}

#custom-arch {
    color: $ACCENT;
    font-size: 16px;
    padding: 0 8px 0 12px;
    margin: 4px 2px;
}

#cpu { color: $GREEN; }
#memory { color: $GREEN; }
#temperature { color: $PEACH; }
#temperature.critical { color: $RED; }
#pulseaudio { color: $ACCENT2; }
#network { color: $SKY; }
#custom-brightness { color: $YELLOW; }
EOF

# ─── 4. Rofi theme ───────────────────────────────────────────────
cat > "$HOME/.config/rofi/theme-current.rasi" << EOF
/* ==========================================================================
   $THEME_NAME — rofi theme (auto-generated by theme-apply)
   ========================================================================== */

* {
    /* Palette */
    rosewater:  $ROSEWATER;
    flamingo:   $FLAMINGO;
    pink:       $PINK;
    mauve:      $MAUVE;
    red:        $RED;
    maroon:     $MAROON;
    peach:      $PEACH;
    yellow:     $YELLOW;
    green:      $GREEN;
    teal:       $TEAL;
    sky:        $SKY;
    sapphire:   $SAPPHIRE;
    blue:       $BLUE;
    lavender:   $LAVENDER;
    text:       $FG;
    subtext1:   $FG_DIM;
    subtext0:   $FG_MUTED;
    overlay2:   $OVERLAY2;
    overlay1:   $OVERLAY1;
    overlay0:   $OVERLAY0;
    surface2:   $SURFACE2;
    surface1:   $SURFACE1;
    surface0:   $SURFACE0;
    base:       $BG;
    mantle:     $BG_DIM;
    crust:      $BG_DARK;

    /* Functional mappings */
    bg:         $(hex_to_rgba "$BG_DARK" "0.88");
    bg-alt:     $(hex_to_rgba "$BG" "0.72");
    fg:         @text;
    fg-alt:     @overlay0;
    accent:     @blue;
    urgent:     @red;

    font: "JetBrainsMono Nerd Font 12";

    background-color: transparent;
    text-color:       @fg;
    margin:           0;
    padding:          0;
    spacing:          0;
}

window {
    location:         center;
    width:            580;
    border:           2px;
    border-color:     @accent;
    border-radius:    12px;
    background-color: @bg;
}

inputbar {
    padding:          14px 20px;
    spacing:          12px;
    children:         [ prompt, entry ];
    background-color: transparent;
}

prompt {
    text-color: @accent;
}

entry {
    placeholder:       "Search...";
    placeholder-color: @overlay0;
    text-color:        @fg;
}

message {
    border:           1px 0 0;
    border-color:     @surface0;
    background-color: transparent;
    padding:          8px 20px;
}

textbox {
    text-color: @subtext1;
}

listview {
    lines:            8;
    columns:          1;
    fixed-height:     true;
    border:           1px 0 0;
    border-color:     @surface0;
    background-color: transparent;
    padding:          4px 0;
}

element {
    padding:          10px 20px;
    spacing:          12px;
    border-radius:    8px;
    background-color: transparent;
}

element normal normal {
    text-color: @fg;
}

element normal urgent {
    text-color: @urgent;
}

element normal active {
    text-color: @green;
}

element selected normal {
    background-color: $(hex_to_rgba "$ACCENT" "0.15");
    text-color:       @accent;
}

element selected urgent {
    background-color: $(hex_to_rgba "$RED" "0.15");
    text-color:       @urgent;
}

element selected active {
    background-color: $(hex_to_rgba "$GREEN" "0.15");
    text-color:       @green;
}

element-icon {
    size:   24px;
    vertical-align: 0.5;
}

element-text {
    text-color:       inherit;
    vertical-align:   0.5;
}
EOF

# ─── 5. Neovim colorscheme ───────────────────────────────────────
cat > "$HOME/.config/nvim/lua/plugins/colorscheme.lua" << EOF
return {
  {
    "$NVIM_PLUGIN",
    name = "$NVIM_COLORSCHEME",
    priority = 1000,
    opts = {
      $NVIM_FLAVOUR
      integrations = {
        cmp = true,
        gitsigns = true,
        neo_tree = true,
        treesitter = true,
        telescope = { enabled = true },
        indent_blankline = { enabled = true },
        native_lsp = {
          enabled = true,
          underlines = {
            errors = { "undercurl" },
            hints = { "undercurl" },
            warnings = { "undercurl" },
            information = { "undercurl" },
          },
        },
        which_key = true,
      },
    },
    config = function(_, opts)
      $NVIM_SETUP
      vim.cmd.colorscheme("$NVIM_COLORSCHEME")
    end,
  },
}
EOF

# ─── 6. Zsh prompt colors (update .zshrc) ────────────────────────
# Replace color block between markers
sed -i '/^# ─── .* Prompt ─/,/^ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE/c\
# ─── '"$THEME_NAME"' Prompt ─────────────────────────────────────\
# Colors from '"$THEME_NAME"' palette\
local ctp_mauve="%F{'"$MAUVE"'}"\
local ctp_blue="%F{'"$ACCENT"'}"\
local ctp_green="%F{'"$GREEN"'}"\
local ctp_peach="%F{'"$PEACH"'}"\
local ctp_red="%F{'"$RED"'}"\
local ctp_teal="%F{'"$TEAL"'}"\
local ctp_yellow="%F{'"$YELLOW"'}"\
local ctp_text="%F{'"$FG"'}"\
local ctp_subtext="%F{'"$FG_MUTED"'}"\
local ctp_overlay="%F{'"$OVERLAY0"'}"\
local reset="%f"\
\
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg='"$OVERLAY0"'"' "$HOME/.zshrc"

# ─── 7. Zsh syntax highlighting ──────────────────────────────────
cat > "$HOME/.zsh/catppuccin_mocha-zsh-syntax-highlighting.zsh" << EOF
# $THEME_NAME Theme (for zsh-syntax-highlighting)
# Auto-generated by theme-apply
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main cursor)
typeset -gA ZSH_HIGHLIGHT_STYLES

## General
ZSH_HIGHLIGHT_STYLES[comment]='fg=$SURFACE2'
## Functions/methods
ZSH_HIGHLIGHT_STYLES[alias]='fg=$GREEN'
ZSH_HIGHLIGHT_STYLES[suffix-alias]='fg=$GREEN'
ZSH_HIGHLIGHT_STYLES[global-alias]='fg=$GREEN'
ZSH_HIGHLIGHT_STYLES[function]='fg=$GREEN'
ZSH_HIGHLIGHT_STYLES[command]='fg=$GREEN'
ZSH_HIGHLIGHT_STYLES[precommand]='fg=$GREEN,italic'
ZSH_HIGHLIGHT_STYLES[autodirectory]='fg=$PEACH,italic'
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=$PEACH'
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=$PEACH'
ZSH_HIGHLIGHT_STYLES[back-quoted-argument]='fg=$ACCENT2'
## Built ins
ZSH_HIGHLIGHT_STYLES[builtin]='fg=$GREEN'
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=$GREEN'
ZSH_HIGHLIGHT_STYLES[hashed-command]='fg=$GREEN'
## Punctuation
ZSH_HIGHLIGHT_STYLES[commandseparator]='fg=$RED'
ZSH_HIGHLIGHT_STYLES[command-substitution-delimiter]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[command-substitution-delimiter-unquoted]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[process-substitution-delimiter]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[back-quoted-argument-delimiter]='fg=$RED'
ZSH_HIGHLIGHT_STYLES[back-double-quoted-argument]='fg=$RED'
ZSH_HIGHLIGHT_STYLES[back-dollar-quoted-argument]='fg=$RED'
## Strings
ZSH_HIGHLIGHT_STYLES[command-substitution-quoted]='fg=$YELLOW'
ZSH_HIGHLIGHT_STYLES[command-substitution-delimiter-quoted]='fg=$YELLOW'
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=$YELLOW'
ZSH_HIGHLIGHT_STYLES[single-quoted-argument-unclosed]='fg=$MAROON'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=$YELLOW'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument-unclosed]='fg=$MAROON'
ZSH_HIGHLIGHT_STYLES[rc-quote]='fg=$YELLOW'
## Variables
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument-unclosed]='fg=$MAROON'
ZSH_HIGHLIGHT_STYLES[dollar-double-quoted-argument]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[assign]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[named-fd]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[numeric-fd]='fg=$FG'
## No category
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=$MAROON'
ZSH_HIGHLIGHT_STYLES[path]='fg=$FG,underline'
ZSH_HIGHLIGHT_STYLES[path_pathseparator]='fg=$RED,underline'
ZSH_HIGHLIGHT_STYLES[path_prefix]='fg=$FG,underline'
ZSH_HIGHLIGHT_STYLES[path_prefix_pathseparator]='fg=$RED,underline'
ZSH_HIGHLIGHT_STYLES[globbing]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[history-expansion]='fg=$ACCENT2'
ZSH_HIGHLIGHT_STYLES[back-quoted-argument-unclosed]='fg=$MAROON'
ZSH_HIGHLIGHT_STYLES[redirection]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[arg0]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[default]='fg=$FG'
ZSH_HIGHLIGHT_STYLES[cursor]='fg=$FG'
EOF

# ─── Save current theme & reload ─────────────────────────────────
echo "$theme" > "$CURRENT_FILE"

# Reload Hyprland
hyprctl reload &>/dev/null || true

# Reload Waybar
pkill waybar 2>/dev/null; sleep 0.3; waybar &>/dev/null &
disown

# Reload Kitty (send SIGUSR1 to all kitty instances)
pkill -USR1 kitty 2>/dev/null || true

notify "Switched to $THEME_NAME"
echo "Done! Theme '$THEME_NAME' applied."
echo "Note: Restart Neovim and open a new terminal for full effect."
